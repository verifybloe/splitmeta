generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PRO
}

enum RatingBand {
  ROOKIE_0_1350
  D_1350_2000
  C_2000_2700
  B_2700_3500
  A_3500_PLUS
}

model User {
  id                       String          @id @default(cuid())
  email                    String          @unique
  emailVerified            DateTime?
  name                     String?
  image                    String?
  iracingCustId            Int?            @unique
  displayName              String?
  plan                     Plan            @default(FREE)
  stripeCustomerId         String?         @unique
  stripeSubscriptionId     String?         @unique
  stripePriceId            String?
  stripeCurrentPeriodEnd   DateTime?
  uploadApiKeyHash         String?         @unique
  uploadApiKeyPrefix       String?
  createdAt                DateTime        @default(now())
  accounts                 Account[]
  sessions                 Session[]
  setups                   Setup[]
  sessionResults           SessionResult[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Car {
  id       String  @id @default(cuid())
  name     String  @unique
  category String
  setups   Setup[]
}

model Track {
  id          String       @id @default(cuid())
  name        String
  config      String?
  seriesWeeks SeriesWeek[]

  @@unique([name, config])
}

model Series {
  id       String       @id @default(cuid())
  name     String       @unique
  category String
  weeks    SeriesWeek[]
}

model SeriesWeek {
  id            String          @id @default(cuid())
  series        Series          @relation(fields: [seriesId], references: [id])
  seriesId      String
  track         Track           @relation(fields: [trackId], references: [id])
  trackId       String
  seasonYear    Int
  seasonQuarter Int
  weekNum       Int
  setups        Setup[]
  results       SessionResult[]
  weeklyMetas   WeeklyMeta[]

  @@unique([seriesId, seasonYear, seasonQuarter, weekNum])
}

model Setup {
  id           String          @id @default(cuid())
  fingerprint  String
  params       String
  uploadedBy   User            @relation(fields: [uploadedById], references: [id])
  uploadedById String
  car          Car             @relation(fields: [carId], references: [id])
  carId        String
  seriesWeek   SeriesWeek      @relation(fields: [seriesWeekId], references: [id])
  seriesWeekId String
  createdAt    DateTime        @default(now())
  results      SessionResult[]

  @@unique([fingerprint, seriesWeekId])
  @@index([seriesWeekId, carId])
}

model SessionResult {
  id            String     @id @default(cuid())
  externalId    String?
  user          User       @relation(fields: [userId], references: [id])
  userId        String
  setup         Setup      @relation(fields: [setupId], references: [id])
  setupId       String
  seriesWeek    SeriesWeek @relation(fields: [seriesWeekId], references: [id])
  seriesWeekId  String
  sof           Int
  iratingBefore Int
  iratingAfter  Int
  finishPos     Int
  fieldSize     Int
  incidents     Int
  bestLapMs     Int
  avgLapMs      Int
  racedAt       DateTime
  createdAt     DateTime   @default(now())

  @@unique([userId, externalId])
  @@index([seriesWeekId, sof])
}

model WeeklyMeta {
  id           String     @id @default(cuid())
  seriesWeek   SeriesWeek @relation(fields: [seriesWeekId], references: [id])
  seriesWeekId String
  band         RatingBand
  computedAt   DateTime   @default(now())
  payload      String

  @@unique([seriesWeekId, band])
}
