# Copy to .env.local for local? Prefer .env (gitignored)

# Neon Postgres connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"
AUTH_URL="https://www.splitmeta.net"
NEXT_PUBLIC_APP_URL="https://www.splitmeta.net"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: https://www.splitmeta.net/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PRICE_ID="price_..." # $8/mo recurring Price ID
STRIPE_WEBHOOK_SECRET="whsec_..."

# Ops (set in Vercel — never commit real values)
CRON_SECRET=""          # Bearer token for /api/cron/compute-meta
ADMIN_GRANT_SECRET=""   # x-admin-secret for /api/admin/grant-pro
