{
  "name": "splitmeta",
  "version": "0.2.0",
  "private": true,
  "description": "SplitMeta desktop app for iRacing",
  "author": "SplitMeta",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "start": "electron .",
    "build:app": "electron-builder --win nsis",
    "postinstall": "node ./node_modules/electron/install.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "net.splitmeta.app",
    "productName": "SplitMeta",
    "copyright": "Copyright © SplitMeta",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "ui/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "shortcutName": "SplitMeta",
      "artifactName": "SplitMeta-Setup.exe"
    }
  }
}
