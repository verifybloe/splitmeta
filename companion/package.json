{
  "name": "splitmeta",
  "version": "0.3.2",
  "private": true,
  "description": "SplitMeta desktop app for iRacing",
  "author": "SplitMeta",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "start": "electron .",
    "generate-icon": "node scripts/generate-icon.mjs",
    "build:app": "npm run generate-icon && electron-builder --win nsis",
    "postinstall": "node ./node_modules/electron/install.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8"
  },
  "build": {
    "appId": "net.splitmeta.app",
    "productName": "SplitMeta",
    "copyright": "Copyright © SplitMeta",
    "icon": "assets/icon.ico",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "ui/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [],
    "publish": [
      {
        "provider": "github",
        "owner": "verifybloe",
        "repo": "splitmeta"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "shortcutName": "SplitMeta",
      "artifactName": "SplitMeta-Setup.exe"
    }
  }
}
